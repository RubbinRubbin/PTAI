{
  "name": "ptai",
  "version": "1.0.0",
  "description": "Personal Trainer AI - Gestione atleti e metriche di allenamento",
  "private": true,
  "scripts": {
    "install:all": "npm run install:backend && npm run install:frontend && npm run install:electron",
    "install:backend": "cd backend && pip install -r requirements.txt",
    "install:frontend": "cd frontend && npm install",
    "install:electron": "cd electron && npm install",
    "dev:backend": "cd backend && python app.py",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && python build_exe.py",
    "build:all": "npm run build:frontend && npm run build:backend",
    "electron:dev": "cd electron && npm run start:dev",
    "electron:start": "cd electron && npm start",
    "electron:dist": "npm run build:all && cd electron && npm run dist",
    "start": "npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "keywords": [
    "personal-trainer",
    "fitness",
    "athletes",
    "metrics",
    "training"
  ],
  "author": "",
  "license": "MIT"
}
